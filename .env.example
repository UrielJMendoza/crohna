# Neon Postgres (get these from neon.tech dashboard)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/chrono?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/chrono?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Mapbox (optional, for production map)
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"
